# Omni-Shield Configuration

# Pimlico API Key for gasless transactions and bundler services
NEXT_PUBLIC_PIMLICO_API_KEY=pim_your_api_key_here

# RPC URL for Sepolia testnet (required for ERC-7715 support)
NEXT_PUBLIC_RPC_URL=https://sepolia.infura.io/v3/your_infura_key

# Envio API Key for HyperSync real-time threat detection
NEXT_PUBLIC_ENVIO_API_KEY=your_envio_api_key_here

# Optional: Custom HyperSync endpoint
NEXT_PUBLIC_HYPERSYNC_URL=https://sepolia.hypersync.xyz